# ── Set up before running the solution with : docker compose up --build dashboard ──
#
# 1. cp .env.example .env
# 2. Set CHAT_MODE=solution
# 3. The database variables below are pre-filled to match the postgres service defined in docker-compose.yml 

CHAT_MODE="example"  # set to solution for the final solution

DB_HOST=postgres
DB_PORT=5432
DB_NAME=technical_assessment
DB_USER=postgres
DB_PASSWORD=postgres

CURRENT_USER=user:bob # this is to test with any user without touching the code